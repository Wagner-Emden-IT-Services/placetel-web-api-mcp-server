{
  "name": "placetel-web-api-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Placetel Web API v2 — full coverage of all 124 endpoints as tools",
  "author": "Wagner-Emden IT Services",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "placetel-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "smoke": "node scripts/smoke.mjs",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wagner-Emden-IT-Services/placetel-web-api-mcp-server.git"
  },
  "homepage": "https://github.com/Wagner-Emden-IT-Services/placetel-web-api-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Wagner-Emden-IT-Services/placetel-web-api-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "placetel",
    "telephony",
    "voip",
    "cti",
    "api"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
